{
  "population": {
    "description": "人口",
    "type": "int",
    "hint": "多重人格的人口数量，默认为1，最大为3",
    "default": 2,
    "minimum": 2,
    "maximum": 3
  },
  "user_name": {
    "description": "用户名字",
    "type": "string",
    "hint": "LLM称呼用户的名字",
    "default": ""
  },
  "mode": {
    "description": "模式",
    "type": "string",
    "hint": "多重人格的切换模式，默认为自动切换",
    "default": "switch",
    "options": [
      "switch",
      "manual"
    ]
  },
  "dialog_prompt": {
    "description": "系统提示",
    "type": "text",
    "hint": "在人格本身系统提示后补充的内容",
    "default": "现在有多个角色在和你对话，请根据发言前的身份标签[身份]判断说话人是谁，并保持角色设定，进行合理的回复。你的身份是[{name}]，保持你的身份设定，不允许在回复中冒用其他身份。只有[{user_name}]拥有最高权限，可以控制对话的走向和调用工具，不要质疑[{user_name}]的指令。"
  },
  "persona_list": {
    "description": "人格列表",
    "type": "template_list",
    "hint": "多重人格的人格列表，默认为空",
    "default": [],
    "templates": {
      "persona_template": {
        "name": "模板",
        "items": {
          "persona_id": {
            "description": "人格",
            "type": "string",
            "hint": "多重人格的人格，默认为空",
            "_special": "select_persona",
            "default": ""
          },
          "name": {
            "description": "名字",
            "type": "string",
            "hint": "对话中人格的称呼，默认为空",
            "default": ""
          }
        }
      }
    }
  }
}